DB_HOST=localhost
DB_NAME=teacher_auth
DB_USER=change_me
DB_PASS=change_me
DB_CHARSET=utf8mb4

SESSION_NAME=teacher_auth_session
SESSION_COOKIE_PATH=/kiweb/
SESSION_LIFETIME=1800
SESSION_ABSOLUTE_LIFETIME=604800

PEPPER=REPLACE_WITH_LONG_RANDOM_STRING

CSRF_TOKEN_NAME=csrf_token

WEBAUTHN_RP_NAME=Example App
WEBAUTHN_RP_ID=example.com
WEBAUTHN_ORIGIN=https://example.com

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=user@example.com
MAIL_PASS=change_me
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Example App

LOGIN_TOKEN_EXPIRY=600
LOGIN_CODE_LENGTH=6

RATE_LIMIT_ATTEMPTS=5
RATE_LIMIT_WINDOW=900
RATE_LIMIT_BLOCK_DURATION=1800

APP_ENV=production
APP_DEBUG=false
TEACHER_SYNC_SECRET=REPLACE_WITH_32_PLUS_CHAR_SECRET
KIWEB_PENDING_SYNC_SECRET=REPLACE_WITH_32_PLUS_CHAR_SECRET
DECLARATION_SCHEDULE_REFRESH_TOKEN=CHANGE_ME
USER_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/CHANGE_ME/exec
USER_SHEET_WEBHOOK_SECRET=CHANGE_ME
USER_SHEET_TIMEOUT=5
USER_SHEET_BACKFILL_TOKEN=CHANGE_ME
