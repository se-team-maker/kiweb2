    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('timesheet-form');
            const dateInput = document.getElementById('date');
            const dateDisplay = document.getElementById('date_display');
            const prevDayButton = document.getElementById('prevDay');
            const todayButton = document.getElementById('todayBtn');
            const nameInput = document.getElementById('name');
            const departmentSelect = document.getElementById('department');
            const submitLoading = document.getElementById('submitLoading');

            function refreshMdlTextfield(inputElement) {
                if (!inputElement) return;
                const wrapper = inputElement.closest('.mdl-textfield');
                if (wrapper && wrapper.MaterialTextfield) {
                    wrapper.MaterialTextfield.checkDirty();
                }
            }

            if (window.componentHandler && typeof window.componentHandler.upgradeDom === 'function') {
                window.componentHandler.upgradeDom();
            }

            if (form) {
                form.addEventListener('submit', function () {
                    if (submitLoading) {
                        submitLoading.classList.add('is-active');
                    }
                    const submitButton = form.querySelector('.submit-button');
                    if (submitButton) {
                        submitButton.disabled = true;
                        submitButton.textContent = '騾∽ｿ｡荳ｭ...';
                    }
                });
            }

            // URL縺九ｉGET繝代Λ繝｡繝ｼ繧ｿ繧貞叙蠕励☆繧矩未謨ｰ
            function getURLParameter(name) {
                const params = new URLSearchParams(window.location.search);
                return params.get(name);
            }

            function normalizeParamValue(value) {
                if (value == null) return '';
                const raw = String(value);
                try {
                    return decodeURIComponent(raw).trim();
                } catch (error) {
                    return raw.trim();
                }
            }

            const nameFromURL = normalizeParamValue(getURLParameter('name') || getURLParameter('teacher'));
            if (nameFromURL && nameInput) {
                nameInput.value = nameFromURL;
                refreshMdlTextfield(nameInput);
            }

            if (departmentSelect) {
                departmentSelect.required = false;
                const departmentFromURL = normalizeParamValue(getURLParameter('department'));
                if (departmentFromURL) {
                    const matchingOption = Array.from(departmentSelect.options).find(function (option) {
                        return option.value === departmentFromURL;
                    });
                    if (!matchingOption) {
                        departmentSelect.appendChild(new Option(departmentFromURL, departmentFromURL));
                    }
                    departmentSelect.value = departmentFromURL;
                } else {
                    departmentSelect.value = '';
                }
            }

            document.querySelectorAll('.mdl-textfield__input').forEach(refreshMdlTextfield);

            // 譌･譛ｬ隱槭・譖懈律驟榊・
            const weekdays = ['譌･', '譛・, '轣ｫ', '豌ｴ', '譛ｨ', '驥・, '蝨・];

            // 譌･莉倥ｒ繝輔か繝ｼ繝槭ャ繝医☆繧矩未謨ｰ (yyyy蟷ｴMM譛・d譌･(aaa) 蠖｢蠑・
            function formatDateJP(date) {
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, '0');
                const day = String(date.getDate()).padStart(2, '0');
                const weekday = weekdays[date.getDay()];
                return `${year}蟷ｴ${month}譛・{day}譌･(${weekday})`;
            }

            // 譌･莉倬未騾｣縺ｮ髢｢謨ｰ
            function setTodayDate() {
                const today = new Date();
                // hidden input縺ｫ譌･莉倥ｒ繧ｻ繝・ヨ (yyyy-MM-dd蠖｢蠑・
                const year = today.getFullYear();
                const month = String(today.getMonth() + 1).padStart(2, '0');
                const day = String(today.getDate()).padStart(2, '0');
                dateInput.value = `${year}-${month}-${day}`;

                // 陦ｨ遉ｺ逕ｨ縺ｮ譌･莉倥ｒ繧ｻ繝・ヨ (yyyy蟷ｴMM譛・d譌･(aaa)蠖｢蠑・
                dateDisplay.textContent = formatDateJP(today);
            }

            function setPreviousDay() {
                const currentDate = new Date(dateInput.value);
                currentDate.setDate(currentDate.getDate() - 1);

                // hidden input縺ｫ譌･莉倥ｒ繧ｻ繝・ヨ (yyyy-MM-dd蠖｢蠑・
                const year = currentDate.getFullYear();
                const month = String(currentDate.getMonth() + 1).padStart(2, '0');
                const day = String(currentDate.getDate()).padStart(2, '0');
                dateInput.value = `${year}-${month}-${day}`;

                // 陦ｨ遉ｺ逕ｨ縺ｮ譌･莉倥ｒ繧ｻ繝・ヨ (yyyy蟷ｴMM譛・d譌･(aaa)蠖｢蠑・
                dateDisplay.textContent = formatDateJP(currentDate);
            }

            // 繧､繝吶Φ繝医Μ繧ｹ繝翫・縺ｮ險ｭ螳・            prevDayButton.addEventListener('click', setPreviousDay);
            todayButton.addEventListener('click', setTodayDate);

            // 蛻晄悄蛹・            setTodayDate();
            calculateTimes();

            // 譎る俣險育ｮ鈴未騾｣縺ｮ髢｢謨ｰ
            function calculateTimes() {
                const startTime = document.getElementById('start_time').value;
                const endTime = document.getElementById('end_time').value;
                const breakStart = document.getElementById('break_start').value;
                const breakEnd = document.getElementById('break_end').value;
                var totalMinutes = (startTime && endTime) ? calculateTimeDifference(startTime, endTime) : null;
                var breakMinutes = (breakStart && breakEnd) ? calculateTimeDifference(breakStart, breakEnd) : 0;
                var workMinutes = (totalMinutes !== null) ? totalMinutes - breakMinutes : null;

                displayTime('total_time', totalMinutes);
                document.getElementById('total_time_value').value = totalMinutes !== null ? totalMinutes : '';
                displayTime('break_time', breakStart && breakEnd ? breakMinutes : null);
                document.getElementById('break_time_value').value = breakStart && breakEnd ? breakMinutes : '';
                displayTime('work_time', workMinutes !== null ? (workMinutes > 0 ? workMinutes : 0) : null);
                document.getElementById('work_time_value').value = workMinutes !== null && workMinutes > 0 ? workMinutes : '';
            }

            // 譎る俣蜈･蜉帙ヵ繧｣繝ｼ繝ｫ繝峨↓繧､繝吶Φ繝医Μ繧ｹ繝翫・繧定ｿｽ蜉
            ['start_time', 'end_time', 'break_start', 'break_end'].forEach(id => {
                document.getElementById(id).addEventListener('change', calculateTimes);
            });

        });

        function calculateTimeDifference(start, end) {
            if (!start || !end) return 0;
            const startDate = new Date("2000-01-01T" + start);
            const endDate = new Date("2000-01-01T" + end);
            if (endDate < startDate) endDate.setDate(endDate.getDate() + 1);
            return Math.round((endDate - startDate) / 60000);
        }

        function displayTime(elementId, minutes) {
            const el = document.getElementById(elementId);
            if (!el) return;
            el.textContent = (minutes !== null && minutes !== undefined) ? `${minutes}蛻・ : '窶・;
        }  
    </script>

    <script>
        (function () {
            function isEmbed() {
                const p = new URLSearchParams(location.search);
                if (p.get('embed') === '1') return true;
                try { return window.self !== window.top; } catch (e) { return true; }
            }
            document.addEventListener('DOMContentLoaded', function () {
                if (isEmbed()) document.body.classList.add('embed');
            });
        })();
    </script>
</body>

</html>

